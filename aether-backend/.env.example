# =====================================================================
# AETHER AI — ENVIRONMENT VARIABLES
# =====================================================================

# Google Vertex AI
GOOGLE_PROJECT_ID=your-project-id
GOOGLE_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./secrets/service-account.json
VERTEX_AI_MODEL_PRO=gemini-1.5-pro-002
VERTEX_AI_MODEL_FLASH=gemini-1.5-flash-002
VERTEX_AI_EMBEDDING_MODEL=text-embedding-004

# PostgreSQL (local Docker)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aether_db
POSTGRES_USER=aether
POSTGRES_PASSWORD=supersecretpassword
DATABASE_URL=postgresql+asyncpg://aether:supersecretpassword@localhost:5432/aether_db

# Redis (local Docker)
REDIS_URL=redis://localhost:6379/0

# Qdrant (local Docker)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=aether_memory

# MinIO (local Docker)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=aether-documents

# Auth
# Generate a secret key: openssl rand -hex 32
JWT_SECRET_KEY=yoursecretkeyhere
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# External Tools
SERPAPI_KEY=your-serpapi-key
BRAVE_SEARCH_API_KEY=your-brave-key

# Rate Limiting
RATE_LIMIT_CHAT=60/minute
RATE_LIMIT_AUTH=10/minute

# App
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,https://aether-ai-pro.vercel.app
